---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Gallery from '../components/Gallery.astro';
import GalleryImage from '../components/GalleryImage.astro';

import justCheckingIn from '../content/docs/Fun/just-checking-in.png';
import hobbies from '../content/docs/Fun/hobbies.png';
import perfectFit from '../content/docs/Fun/perfect-fit.png';
import introduction from '../content/docs/Fun/introduction.png';
import dependency from '../content/docs/Fun/dependency.png';
import standards from '../content/docs/Fun/standards.png';
import codeEntropy from '../content/docs/Fun/code-entropy.png';
import dejaVu from '../content/docs/Fun/deja-vu.png';
import dilbertCubicles from '../content/docs/Fun/dilbert-cubicles.png';
import abychNeslaZima from '../content/docs/Fun/abych-nesla-zima.png';
import aiCompaniesInTrouble from '../content/docs/Fun/ai-companies-in-trouble.png';
import azNaVekyPekarna from '../content/docs/Fun/az-na-veky-pekarna.png';
import bearHandsOhDeer from '../content/docs/Fun/bear-hands-oh-deer.png';
import czechBeerAbroadMeme from '../content/docs/Fun/czech-beer-abroad-meme.png';
import dilbertInvestmentAdvice from '../content/docs/Fun/dilbert-investment-advice.png';
import bedrichFirefly from '../content/docs/Fun/bedrich-nechce-zhasnout-prdel.png';
import bitvaUProkrastina from '../content/docs/Fun/bitva-u-prokrastina.png';
import potucekNebuduMeandrovat from '../content/docs/Fun/potucek-nebudu-meandrovat.png';
import poohPigletCholera from '../content/docs/Fun/pooh-piglet-cholera.png';
import flatEarthAquarium from '../content/docs/Fun/flat-earth-aquarium.png';
import nonSequiturAnswers from '../content/docs/Fun/non-sequitur-answers.png';
import schrodingersChristmas from '../content/docs/Fun/schrodingers-christmas-present.png';
---

<StarlightPage frontmatter={{ title: 'Fun', tableOfContents: false, template: 'splash' }}>
	<h2>Česky</h2>
	<Gallery>
		<GalleryImage src={abychNeslaZima} title="Abych nešla zima" />
		<GalleryImage src={bedrichFirefly} title="Mamííí, Bedřich nechce zhasnout prdel!" />
		<GalleryImage
		src={czechBeerAbroadMeme}
		title="Czechs tasting the local beer while abroad on holiday"
		/>
		<GalleryImage
			src={flatEarthAquarium}
			title="To akvárko už vyleješ do hajzlu, tisíc let se o to vůbec nestaráš…"
		/>
		<GalleryImage src={azNaVekyPekarna} title="Až na věky… (pekárna)" />
	</Gallery>

	<h2>Faux pas comics</h2>
	<Gallery>
		<GalleryImage
			src={bitvaUProkrastina}
			title="K bitvě u Prokrastina nikdy nedošlo…"
			href="https://pas-faux-pas.blogspot.com/2015/11/bitva.html"
		/>
		<GalleryImage
			src={potucekNebuduMeandrovat}
			title="Chladný potůček brblá… (nechci meandrovat)"
			href="https://pas-faux-pas.blogspot.com/2021/12/potucek.html"
		/>
	</Gallery>

	<h2>Monkey User</h2>
	<Gallery>
		<GalleryImage src={perfectFit} title="Perfect fit" href="https://www.monkeyuser.com/2021/perfect-fit/" />
		<GalleryImage src={introduction} title="Introduction" href="https://www.monkeyuser.com/2021/introduction/" />
		<GalleryImage src={codeEntropy} title="Code entropy" href="https://www.monkeyuser.com/2019/code-entropy/" />
		<GalleryImage src={dejaVu} title="Déjà vu" href="https://www.monkeyuser.com/2019/deja-vu/" />
	</Gallery>

	<h2>AI in Trouble</h2>
	<Gallery>
		<GalleryImage
			src={aiCompaniesInTrouble}
			title="Come quickly! The AI companies are in trouble — I'm on my way"
			href="https://bsky.app/profile/smoothdunk2.bsky.social/post/3m5c7htzgw22u"
		/>
	</Gallery>

	<h2>Work Chronicles</h2>
	<Gallery>
		<GalleryImage src={justCheckingIn} title="Just checking in" href="https://www.workchronicles.com/p/comic-just-checking-in-0b4" />
		<GalleryImage src={hobbies} title="Hobbies" href="https://www.workchronicles.com/p/comic-hobbies" />
	</Gallery>

	<h2>Non Sequitur</h2>
	<Gallery>
		<GalleryImage
			src={nonSequiturAnswers}
			title="Simple but wrong / Complex but right"
			href="https://www.gocomics.com/nonsequitur"
		/>
	</Gallery>

	<h2>Schrödinger's Christmas Present</h2>
	<Gallery>
		<GalleryImage
			src={schrodingersChristmas}
			title="It's not another dead kitten, is it?"
		/>
	</Gallery>

	<h2>Bear hands</h2>
	<Gallery>
		<GalleryImage
			src={bearHandsOhDeer}
			title="I'll fight you with my bear hands! — Oh deer"
		/>
	</Gallery>

	<h2>Pooh and Piglet</h2>
	<Gallery>
		<GalleryImage
			src={poohPigletCholera}
			title="What do you think we will catch, Piglet? — Probably cholera."
		/>
	</Gallery>

	<h2>Dilbert</h2>
	<Gallery>
		<GalleryImage
			src={dilbertInvestmentAdvice}
			title="How does advice actually work? — It only works for the people that give it."
			href="https://dilbert.com/"
		/>
		<GalleryImage
		src={dilbertCubicles}
		title="How have I never noticed this before?"
		href="https://dilbert.com/"
	/>
	</Gallery>

	<h2>XKCD comics</h2>
	<Gallery>
		<GalleryImage src={dependency} title="Dependencies" href="https://xkcd.com/2347/" />
		<GalleryImage src={standards} title="Standards" href="https://xkcd.com/927/" />
	</Gallery>
</StarlightPage>
