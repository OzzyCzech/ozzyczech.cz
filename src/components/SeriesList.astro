---
import Series from "./Series.astro";
const html = await Astro.slots.render('default');
const items = [...html.matchAll(/<li>(?<content>[\s\S]*?)<\/li>/g)].map((m) => {
	const content = m.groups?.content ?? '';
	const hrefMatch = content.match(/href="(?<href>[^"]+)"/);
	const title = content.replace(/<[^>]+>/g, '').trim();
	return { title, href: hrefMatch?.groups?.href };
});
---

<div>
	<ul class="p-0 m-0 list-none grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-4 gap-3">
		{items.map(({ title, href }) => (
			<Series title={title} href={href}/>
		))}
	</ul>
</div>
